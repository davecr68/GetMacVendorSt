$buttonExcel_Click={
	#TODO: Place custom script here
	#TODO: Place custom script here
	# Choose whether to write header. Use EnableWithoutHeaderText instead to omit header.
	$dataGridView2.ClipboardCopyMode = 'EnableAlwaysIncludeHeaderText'
	# Select all the cells
